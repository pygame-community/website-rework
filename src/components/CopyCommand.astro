---
import { Copy } from '@geist-ui/icons';

interface Props {
  command: string;
  className?: string;
}

const { command, className = '' } = Astro.props;
---

<div class={`flex items-center justify-between w-80 gap-2 rounded-lg border bg-muted px-4 py-2 font-mono ${className}`}>
  <code class="flex-1 text-foreground text-left">
    <span class="text-muted-foreground">$ </span>
    {command}
  </code>
  <button
    class="size-8 shrink-0 flex items-center justify-center rounded-lg hover:bg-accent transition"
    aria-label="Copy command"
    data-command={command}
    onclick="copyCommand(this)"
  >
    <Copy />
  </button>
</div>
