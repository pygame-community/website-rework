---
import '@fontsource/geist';
import '@fontsource/dynapuff';

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Image } from 'astro:assets';

import CopyCommand from '@/components/CopyCommand.astro';

import { Highlighter } from '@/components/ui/highlighter';

import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/global.css';
import FormattedDate from '@/components/FormattedDate.astro';
import { Button } from '@/components/ui/button';
import { IconBrandDiscord, IconBrandGithub, IconBrandX } from '@tabler/icons-react';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title ? title : SITE_TITLE} description={description ? description : SITE_DESCRIPTION} />
    <script>
      const theme = localStorage.getItem('theme');
  
      // theme is saved to localstorage, but it also needs to be applied to the html
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
